{
  "$schema": "https://ui.shadcn.com/schema/registry.json",
  "name": "solar-ui",
  "homepage": "https://solar-ui.vercel.app",
  "items": [
    {
      "name": "utils",
      "type": "registry:lib",
      "description": "Utility function for merging Tailwind classes.",
      "dependencies": ["clsx", "tailwind-merge"],
      "files": [
        {
          "path": "lib/utils.ts",
          "type": "registry:lib"
        }
      ]
    },
    {
      "name": "use-mobile",
      "type": "registry:hook",
      "description": "Hook for detecting mobile viewport.",
      "files": [
        {
          "path": "hooks/use-mobile.tsx",
          "type": "registry:hook"
        }
      ]
    },
    {
      "name": "solar-ui",
      "type": "registry:theme",
      "description": "SolarUI color tokens — Radix Colors mapped to semantic scales (default, brand, error, success, warning, info).",
      "dependencies": ["@radix-ui/colors"],
      "files": [
        {
          "path": "registry/solar-ui.css",
          "type": "registry:file",
          "target": "app/solar-ui.css"
        }
      ],
      "docs": "Add `@import \"./solar-ui.css\";` at the very top of your globals.css (before `@import \"tailwindcss\"`)."
    },
